# EAS archive exclusions — keep upload small (~50MB target)

# Web app not needed for mobile builds
apps/web/

# Root-level native dirs only (nothing there). apps/mobile/android & apps/mobile/ios
# are TRACKED native code (bare workflow) and MUST be uploaded so EAS skips prebuild.
/android/
/ios/

# Node modules — EAS installs fresh
node_modules/
apps/mobile/node_modules/
packages/*/node_modules/

# Git history
.git/

# Test artifacts
tests/
apps/web/test-results/
.maestro/screenshots/
screenshots/

# Mobile native build outputs — heavy, rebuilt by EAS on the worker
# android/app/build alone is 1.4 GB locally; ios/Pods is 227 MB
apps/mobile/android/app/build/
apps/mobile/android/build/
apps/mobile/android/.gradle/
apps/mobile/android/.cxx/
apps/mobile/ios/Pods/
apps/mobile/ios/build/
apps/mobile/ios/DerivedData/

# Build artifacts
build-extract/
build.ipa
*.apk
*.aab

# Local dev junk
.expo/
apps/mobile/.expo/
.expo-shared/
.metro-cache/
dist-*/
expo-export-test/

# IDE
.vscode/
.idea/

# Root-level Maestro screenshots and debug PNGs
/*.png
/*.PNG

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
