# EAS archive exclusions — keep upload small (~50MB target)

# Web app not needed for mobile builds
apps/web/

# Native build outputs — EAS rebuilds these from scratch
android/
ios/
apps/mobile/android/
apps/mobile/ios/

# Node modules — EAS installs fresh
node_modules/
apps/mobile/node_modules/
packages/*/node_modules/

# Git history
.git/

# Test artifacts
tests/
apps/web/test-results/
.maestro/screenshots/
screenshots/

# Build artifacts
build-extract/
build.ipa
*.apk
*.aab

# Local dev junk
.expo/
apps/mobile/.expo/
.expo-shared/
.metro-cache/

# IDE
.vscode/
.idea/

# Root-level Maestro screenshots and debug PNGs
/*.png
/*.PNG

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
