# KalpX Mobile — Environment Variable Example
# Copy to .env.local for local overrides (git-ignored).
# All EXPO_PUBLIC_* vars are baked at EAS build time — a new build is required for production changes.
# EAS profile-level vars are defined in eas.json; these are for local Metro bundler dev only.
# See docs/feature-flags-and-env.md for full documentation.

# ── API routing ───────────────────────────────────────────────────────────────
# "prod" → kalpx.com, anything else → dev.kalpx.com
# Set to "prod" in EAS production profile (eas.json). Leave empty for local dev.
EXPO_PUBLIC_API_ENV=

# ── Feature flags (build-time) ────────────────────────────────────────────────
# V3 dashboard UI (set to 1 in .env and EAS production)
EXPO_PUBLIC_MITRA_V3_NEW_DASHBOARD=1

# Rooms v3.1 UI (set to 1 in .env and EAS production)
EXPO_PUBLIC_MITRA_V3_ROOMS=1

# Recognition backend flag (production EAS profile only — do not enable locally without S0)
EXPO_PUBLIC_MITRA_V3_RECOGNITION_BACKEND=

# Tell Mitra thread UI: chip-based conversation + room recommendation card.
# For local dev only. Requires a new EAS build to enable on production.
# Requires backend MITRA_V3_TELL_MITRA_ENABLED=1 + MITRA_ROOMS_V31=1 + MITRA_ROOM_GUIDED=1.
# See docs/feature-flags-and-env.md §6 for the full checklist.
EXPO_PUBLIC_MITRA_TELL_MITRA_THREAD_UI=
# RoomJourneyRenderer — phase-based inline room renderer (default OFF)
EXPO_PUBLIC_MITRA_ROOM_JOURNEY_V1=
# Per-room allowlist (comma-separated room IDs). Leave blank to allow all 6 rooms when flag is ON.
EXPO_PUBLIC_ROOM_JOURNEY_LIVE_ROOMS=

# ── Analytics / tracking ──────────────────────────────────────────────────────
# Facebook CAPI — not yet integrated; placeholder only
EXPO_PUBLIC_FB_CAPI_TOKEN=
