<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">

  <!-- Strip READ_MEDIA_* permissions injected by expo-media-library.
       The app only saves generated images (write-only); it never reads the gallery. -->
  <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" tools:node="remove"/>
  <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" tools:node="remove"/>
  <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" tools:node="remove"/>
  <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" tools:node="remove"/>
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" tools:node="remove"/>
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" tools:node="remove"/>

  <!-- Existing permissions -->
  <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
  <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
  <uses-permission android:name="android.permission.INTERNET"/>
  <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
  <uses-permission android:name="android.permission.RECORD_AUDIO"/>
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
  <uses-permission android:name="android.permission.VIBRATE"/>

  <!-- Live Activity / Foreground Service permissions -->

  <!-- Required on API 28+ to run a foreground service -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

  <!-- Required on API 34+ (Android 14) for foreground services of type dataSync.
       dataSync maps to our use-case: active data tracking during a chanting session. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>

  <!-- Required on API 33+ (Android 13) to post notifications.
       Requested at runtime from JS before calling startActivity/startSankalpActivity. -->
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

  <queries>
    <intent>
      <action android:name="android.intent.action.VIEW"/>
      <category android:name="android.intent.category.BROWSABLE"/>
      <data android:scheme="https"/>
    </intent>
  </queries>

  <application android:name=".MainApplication" android:label="@string/app_name" android:icon="@mipmap/ic_launcher" android:roundIcon="@mipmap/ic_launcher_round" android:allowBackup="true" android:theme="@style/AppTheme" android:supportsRtl="true">
    <meta-data android:name="com.google.android.gms.wallet.api.enabled" android:value="true"/>
    <meta-data android:name="expo.modules.updates.ENABLED" android:value="false"/>
    <meta-data android:name="expo.modules.updates.EXPO_UPDATES_CHECK_ON_LAUNCH" android:value="ALWAYS"/>
    <meta-data android:name="expo.modules.updates.EXPO_UPDATES_LAUNCH_WAIT_MS" android:value="0"/>

    <activity android:name=".MainActivity" android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|uiMode" android:launchMode="singleTask" android:windowSoftInputMode="adjustResize" android:theme="@style/Theme.App.SplashScreen" android:exported="true" android:screenOrientation="portrait">
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
      <intent-filter>
        <action android:name="android.intent.action.VIEW"/>
        <category android:name="android.intent.category.DEFAULT"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <data android:scheme="kalpx"/>
        <data android:scheme="exp+kalpx"/>
      </intent-filter>
    </activity>

    <!-- KalpxLiveActivityService: foreground service backing the chanting/sankalp notification.
         foregroundServiceType="dataSync" is required on API 34+ (Android 14).
         On API 24–33 the attribute is parsed but not enforced.
         exported=false: this service is only ever started from within the app. -->
    <service
        android:name=".KalpxLiveActivityService"
        android:foregroundServiceType="dataSync"
        android:exported="false"/>

    <!-- KalpxWearListenerService: receives messages from Wear OS app via Wearable Data Layer.
         Forwards watch_message events to React Native via KalpxWatchConnectivityModule. -->
    <service
        android:name=".KalpxWearListenerService"
        android:exported="true">
      <intent-filter>
        <action android:name="com.google.android.gms.wearable.DATA_CHANGED"/>
        <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED"/>
      </intent-filter>
    </service>

    <!-- ChantIncrementReceiver: handles "ॐ Chant" notification action button taps.
         Mirrors IncrementChantIntent (iOS 17+ LiveActivityIntent).
         exported=false: receives only internal broadcasts via explicit Intent. -->
    <receiver
        android:name=".ChantIncrementReceiver"
        android:exported="false">
      <intent-filter>
        <action android:name="com.kalpx.app.LA_INCREMENT"/>
      </intent-filter>
    </receiver>

  </application>
</manifest>