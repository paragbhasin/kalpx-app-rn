<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY manifest. Registers the emulator sync relay receiver so phone↔watch sync
  can be tested on emulators (Wear pairing is unavailable there). This receiver and its
  class live only in the debug source set, so they are NOT present in release builds.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <receiver
            android:name=".sync.RelaySyncReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.kalpx.wear.RELAY_SYNC"/>
            </intent-filter>
        </receiver>
    </application>
</manifest>
