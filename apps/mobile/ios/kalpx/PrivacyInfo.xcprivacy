	<!--
	  NSPrivacyCollectedDataTypes — ENGINEERING PATCH (2026-05-18)
	  MUST be reviewed against the final Privacy Policy and App Store privacy
	  nutrition label before any App Store submission. Do not ship without legal sign-off.

	  Declared: Device/Installation ID (FCM push token)
	    - Linked to user: Yes (token stored against user account for push delivery)
	    - Used for tracking: No (not used for cross-app or cross-site tracking)
	    - Purpose: App Functionality (push notification delivery only)
	-->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
	</array>
	<key>NSPrivacyTracking</key>
	<false/>
</dict>
</plist>
