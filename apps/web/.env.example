# KalpX Web — Environment Variable Example
# Copy to .env.development.local for local overrides.
# All VITE_* vars are build-time: a full rebuild is required after any change.
# All vars must be accessed via WEB_ENV in apps/web/src/lib/env.ts — never use import.meta.env directly.
# See docs/feature-flags-and-env.md for full documentation.

# ── API endpoints ─────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://dev.kalpx.com/api
VITE_API_IMAGE_BASE_URL=https://dev.kalpx.com

# ── Analytics / tracking ──────────────────────────────────────────────────────
VITE_META_PIXEL_ID=
VITE_SENTRY_DSN=

# ── Payments ──────────────────────────────────────────────────────────────────
# Use Stripe TEST keys for dev/staging. Never commit live keys.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Auth ──────────────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_RECAPTCHA_SITE_KEY=

# ── Feature flags (build-time) ────────────────────────────────────────────────
# Tell Mitra thread UI: chip-based conversation + room recommendation card.
# Requires backend MITRA_V3_TELL_MITRA_ENABLED=1 + MITRA_ROOMS_V31=1 + MITRA_ROOM_GUIDED=1.
# See docs/feature-flags-and-env.md §6 for the full checklist.
VITE_MITRA_TELL_MITRA_THREAD_UI=1

# ── Locale gate ───────────────────────────────────────────────────────────────
# Comma-separated list of locales to expose in the language selector UI.
# Supported values: en, hi, te. Prod must be en only.
# Dev default: en,hi,te
VITE_ENABLED_LOCALES=en,hi,te

# ── Playwright test vars (not used at runtime, CI/test only) ──────────────────
# PW_BASE_URL=http://localhost:5173
# PW_SKIP_WEBSERVER=false
# PW_DAY3_EMAIL=
# PW_DAY3_PASSWORD=
# PW_DAY7_EMAIL=
# PW_DAY7_PASSWORD=
# PW_DAY14_EMAIL=
# PW_DAY14_PASSWORD=
