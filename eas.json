{
  "cli": {
    "version": ">= 0.53.0"
  },
  "build": {
    "production": {
      "env": {
        "EXPO_UPDATES_DISABLED": "1"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "preview": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    }
  }
}
