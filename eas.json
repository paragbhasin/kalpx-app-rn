{
  "cli": {
    "version": ">= 0.53.0"
  },
  "build": {
    "production": {
      "environment": "production",
      "env": {
        "EXPO_UPDATES_DISABLED": "1"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "preview": {
      "extends": "production",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "simulator": {
      "extends": "preview",
      "ios": {
        "simulator": true
      }
    },
    "development": {
      "extends": "preview",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}
