{
  "name": "kalpx-monorepo",
  "private": true,
  "scripts": {
    "mobile": "cd apps/mobile && npx expo start",
    "web:dev": "pnpm --filter @kalpx/web dev",
    "web:build": "pnpm --filter @kalpx/web build",
    "web:typecheck": "pnpm --filter @kalpx/web typecheck",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "postinstall-postinstall",
      "protobufjs",
      "unrs-resolver",
      "esbuild"
    ]
  }
}
