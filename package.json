{
  "name": "kalpx-monorepo",
  "private": true,
  "main": "./apps/mobile/AppEntry.js",
  "scripts": {
    "mobile": "cd apps/mobile && npx expo start",
    "web:dev": "pnpm --filter @kalpx/web dev",
    "web:build": "pnpm --filter @kalpx/web build",
    "web:typecheck": "pnpm --filter @kalpx/web typecheck",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
