{
  "name": "kalpx-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "eas-build-pre-install": "corepack enable && corepack prepare pnpm@10.33.2 --activate && pnpm --version",
    "mobile": "cd apps/mobile && npx expo start",
    "web:dev": "pnpm --filter @kalpx/web dev",
    "web:build": "pnpm --filter @kalpx/web build",
    "web:typecheck": "pnpm --filter @kalpx/web typecheck",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
